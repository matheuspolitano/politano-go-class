# Compiled Binaries
# Ignore all executables generated by 'go build'
*.exe
*.exe~
*.dll
*.so
*.dylib

# Specific binaries you might create
main
debug
__debug_bin

# Packages and Dependencies
# It's better to download dependencies via 'go mod download' than to store them in Git
vendor/

# Test and Coverage Tools
*.test
*.out
coverage.txt

# IDE Configurations (Code Editors)
# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (GoLand, IntelliJ, etc.)
.idea/

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Environment Variables
# Never commit API keys or passwords to GitHub!
.env
*.env
.env.local

# Temporary Files
*.log
tmp/
bin/